generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum BillingMode {
  CONTRACT
  EXTRA
  BOTH
}

enum InterventionType {
  ORDINARY
  EXTRA
  EMERGENCY
}

enum PhotoType {
  BEFORE
  AFTER
  OTHER
}

enum InvoiceDraftStatus {
  BOZZA
  PRONTO_EXPORT
  ESPORTATO
  REGISTRATO_SAGE
  ANNULLATO
}

enum QuoteStatus {
  BOZZA
  INVIATO
  ACCETTATO
  RIFIUTATO
  SCADUTO
}

enum InvoiceLineSource {
  MANUAL
  INTERVENTION_HOURS
  INTERVENTION_MATERIAL
  QUOTE_LINE
  DISCOUNT
}

enum VatCode {
  STANDARD
  RIDOTTA
  ALLOGGIO
  ESENTE
}

enum SageExportStatus {
  GENERATED
  CONFIRMED_IMPORT
  CANCELLED
}

enum AccountingConfigCategory {
  ACCOUNT
  VAT_CODE
  COST_CENTER
  GENERAL
}

enum ClientType {
  AMMINISTRAZIONE
  FIDUCIARIA
  PRIVATO
}

enum ServiceCategory {
  ORDINARIO
  EXTRA
}

enum WorkType {
  ORDINARIO
  EXTRA
  TRASFERTA
  REGIA
  FORFAIT
  STRAORDINARIO
  PICCHETTO
  EMERGENZA
}

enum InterventionStatus {
  IN_CORSO
  COMPLETATO
  VALIDATO
  PRONTO_FATTURA
}

enum PhotoKind {
  PRIMA
  DOPO
  ANOMALIA
}

model Role {
  id          Int    @id @default(autoincrement())
  code        String @unique
  name        String
  description String?
  users       User[]

  @@map("roles")
}

model User {
  id              Int      @id @default(autoincrement())
  roleId          Int      @map("role_id")
  teamId          Int?     @map("team_id")
  firstName       String   @map("first_name")
  lastName        String   @map("last_name")
  email           String   @unique
  passwordHash    String   @default("") @map("password_hash")
  hourlyCostCents Int?     @map("hourly_cost_cents")
  qualifications  String?
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  role            Role     @relation(fields: [roleId], references: [id])
  interventions   Intervention[] @relation("InterventionCreator")
  workerLinks     InterventionWorker[]
  exports         SageExport[]   @relation("SageExportExporter")
  importedExports SageExport[]   @relation("SageExportImporter")
  validatedInterventions Intervention[] @relation("InterventionValidator")
  uploadedPhotos  InterventionPhoto[]
  auditLogs       InterventionAuditLog[]
  generatedReports GeneratedReport[]
  quotes           Quote[]          @relation("QuoteCreator")
  invoiceDrafts    InvoiceDraft[]   @relation("InvoiceCreator")
  uploadedDocuments  IncomingDocument[] @relation("IncomingDocumentCreator")
  validatedDocuments IncomingDocument[] @relation("IncomingDocumentValidator")
  emailsSent         EmailLog[]

  @@map("users")
}

model Client {
  id                Int               @id @default(autoincrement())
  businessName      String            @map("business_name")
  type              ClientType        @default(AMMINISTRAZIONE)
  address           String?           @map("billing_address")
  billingEmail      String?           @map("billing_email")
  phone             String?
  contactName       String?           @map("contact_name")
  notes             String?
  specialConditions String?           @map("special_conditions")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  sageCustomerNumber String?           @map("sage_customer_number")
  properties        Property[]
  contracts         CustodyContract[]
  invoiceDrafts     InvoiceDraft[]
  quotes            Quote[]
  incomingDocuments IncomingDocument[]

  @@map("clients")
}

model Property {
  id                  Int               @id @default(autoincrement())
  clientId            Int               @map("client_id")
  name                String
  address             String
  serviceFrequency    String?           @map("service_frequency")
  expectedWeeklyHours Float?            @map("expected_weekly_hours")
  operationalNotes    String?           @map("operational_notes")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  client              Client            @relation(fields: [clientId], references: [id])
  contracts           CustodyContract[]
  interventions       Intervention[]
  quotes              Quote[]
  invoiceDrafts       InvoiceDraft[]
  incomingDocuments   IncomingDocument[]

  @@index([clientId], map: "idx_properties_client_id")
  @@map("properties")
}

model Service {
  id                    Int               @id @default(autoincrement())
  code                  String            @unique
  name                  String
  category              ServiceCategory   @default(ORDINARIO)
  unit                  String            @default("ora")
  billingMode           BillingMode       @default(BOTH) @map("billing_mode")
  defaultHourlyRateCents Int?            @map("default_hourly_rate_cents")
  defaultUnitRateCents Int?              @map("default_unit_rate_cents")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  interventions         Intervention[]
  contracts             CustodyContractService[]

  @@map("services")
}

model CustodyContract {
  id                 Int                      @id @default(autoincrement())
  clientId           Int                      @map("client_id")
  propertyId         Int                      @map("property_id")
  weeklyFrequency    Int?                     @map("weekly_frequency")
  expectedHoursMonthly Float?                 @map("expected_hours_monthly")
  monthlyPriceCents  Int                      @map("monthly_price_cents")
  includedServices   String?                  @map("included_services")
  excludedServices   String?                  @map("excluded_services")
  startsOn           DateTime?                @map("starts_on")
  endsOn             DateTime?                @map("ends_on")
  isActive           Boolean                  @default(true) @map("is_active")
  createdAt          DateTime                 @default(now()) @map("created_at")
  updatedAt          DateTime                 @updatedAt @map("updated_at")
  client             Client                   @relation(fields: [clientId], references: [id])
  property           Property                 @relation(fields: [propertyId], references: [id])
  controls           ContractControl[]
  services           CustodyContractService[]

  @@index([propertyId], map: "idx_contracts_property_id")
  @@map("custody_contracts")
}

model CustodyContractService {
  contractId Int @map("contract_id")
  serviceId  Int @map("service_id")
  contract   CustodyContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  service    Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([contractId, serviceId])
  @@map("custody_contract_services")
}

model Intervention {
  id                 Int                @id @default(autoincrement())
  propertyId         Int                @map("property_id")
  serviceId          Int?               @map("service_id")
  createdByUserId    Int                @map("created_by_user_id")
  interventionType   InterventionType   @default(ORDINARY) @map("intervention_type")
  workType           WorkType           @default(ORDINARIO) @map("work_type")
  status             InterventionStatus @default(IN_CORSO)
  startsAt           DateTime?          @map("starts_at")
  endsAt             DateTime?          @map("ends_at")
  startedAt          DateTime?          @map("started_at")
  endedAt            DateTime?          @map("ended_at")
  durationMinutes    Int?               @map("duration_minutes")
  notes              String?
  anomalyReport      String?            @map("anomaly_report")
  anomaly            String?
  isBillableExtra    Boolean            @default(false) @map("is_billable_extra")
  isExtra            Boolean            @default(false) @map("is_extra")
  validatedByOffice  Boolean            @default(false) @map("validated_by_office")
  readyForSage       Boolean            @default(false) @map("ready_for_sage")
  startLat           Float?             @map("start_lat")
  startLng           Float?             @map("start_lng")
  startAccuracy      Float?             @map("start_accuracy")
  endLat             Float?             @map("end_lat")
  endLng             Float?             @map("end_lng")
  clientSignatureUrl String?            @map("client_signature_url")
  clientSignerName   String?            @map("client_signer_name")
  validatedById      Int?               @map("validated_by_id")
  validatedAt        DateTime?          @map("validated_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  property           Property           @relation(fields: [propertyId], references: [id])
  service            Service?           @relation(fields: [serviceId], references: [id])
  createdByUser      User               @relation("InterventionCreator", fields: [createdByUserId], references: [id])
  validatedBy        User?              @relation("InterventionValidator", fields: [validatedById], references: [id])
  workers            InterventionWorker[]
  photos             InterventionPhoto[]
  materials          InterventionMaterial[]
  report             WorkReport?
  invoiceDrafts      InvoiceDraft[]
  auditLogs          InterventionAuditLog[]
  incomingDocuments  IncomingDocument[]

  @@index([propertyId], map: "idx_interventions_property_id")
  @@index([readyForSage], map: "idx_interventions_ready_for_sage")
  @@index([status], map: "idx_interventions_status")
  @@map("interventions")
}

model InterventionWorker {
  interventionId Int     @map("intervention_id")
  userId         Int     @map("user_id")
  isLead         Boolean @default(false) @map("is_lead")
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([interventionId, userId])
  @@map("intervention_workers")
}

model InterventionPhoto {
  id             Int       @id @default(autoincrement())
  interventionId Int       @map("intervention_id")
  photoType      PhotoType @default(OTHER) @map("photo_type")
  kind           PhotoKind @default(DOPO)
  filePath       String?   @map("file_path")
  url            String    @default("")
  publicId       String?   @map("public_id")
  uploadedById   Int?      @map("uploaded_by_id")
  uploadedAt     DateTime  @default(now()) @map("uploaded_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  intervention   Intervention @relation(fields: [interventionId], references: [id])
  uploadedBy     User?    @relation(fields: [uploadedById], references: [id])

  @@map("intervention_photos")
}

model Material {
  id            Int      @id @default(autoincrement())
  code          String   @unique
  name          String
  unit          String
  unitCostCents Int      @map("unit_cost_cents")
  stockQuantity Float?   @map("stock_quantity")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  interventions InterventionMaterial[]

  @@map("materials")
}

model InterventionMaterial {
  id                Int      @id @default(autoincrement())
  interventionId    Int      @map("intervention_id")
  materialId        Int      @map("material_id")
  quantity          Float
  unitCostCents     Int?     @map("unit_cost_cents")
  notes             String?
  billableSeparately Boolean @default(false) @map("billable_separately")
  intervention      Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  material          Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@map("intervention_materials")
}

model WorkReport {
  id                   Int      @id @default(autoincrement())
  interventionId       Int      @unique @map("intervention_id")
  internalSummary      String?  @map("internal_summary")
  clientSummary        String?  @map("client_summary")
  employeeTotalMinutes Int?     @map("employee_total_minutes")
  customerSignatureName String? @map("customer_signature_name")
  pdfPath              String?  @map("pdf_path")
  createdAt            DateTime @default(now()) @map("created_at")
  intervention         Intervention @relation(fields: [interventionId], references: [id])

  @@map("work_reports")
}

model ContractControl {
  id            Int      @id @default(autoincrement())
  contractId    Int      @map("contract_id")
  periodStart   DateTime @map("period_start")
  periodEnd     DateTime @map("period_end")
  expectedHours Float    @map("expected_hours")
  actualHours   Float    @map("actual_hours")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  contract      CustodyContract @relation(fields: [contractId], references: [id])

  @@index([contractId], map: "idx_contract_controls_contract_id")
  @@map("contract_controls")
}

model InvoiceDraft {
  id                   String             @id @default(cuid())
  number               String             @unique
  year                 Int
  sequence             Int
  clientId             Int                @map("client_id")
  propertyId           Int?               @map("property_id")
  subject              String
  status               InvoiceDraftStatus @default(BOZZA)
  documentDate         DateTime           @map("document_date")
  dueDate              DateTime           @map("due_date")
  paymentTermsDays     Int                @default(30) @map("payment_terms_days")
  notes                String?
  fromQuoteId          String?            @map("from_quote_id")
  fromInterventionId   Int?               @map("from_intervention_id")
  subtotalCents        Int                @default(0) @map("subtotal_cents")
  vatTotalCents        Int                @default(0) @map("vat_total_cents")
  totalCents           Int                @default(0) @map("total_cents")
  currency             String             @default("CHF")
  locale               String             @default("it")
  pdfUrl               String?            @map("pdf_url")
  pdfPublicId          String?            @map("pdf_public_id")
  exportedAt           DateTime?          @map("exported_at")
  exportedBatchId      String?            @map("exported_batch_id")
  createdById          Int                @map("created_by_id")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  client               Client             @relation(fields: [clientId], references: [id])
  property             Property?          @relation(fields: [propertyId], references: [id])
  createdBy            User               @relation("InvoiceCreator", fields: [createdById], references: [id])
  exportBatch          SageExport?        @relation("InvoiceExportBatch", fields: [exportedBatchId], references: [id])
  fromIntervention     Intervention?      @relation(fields: [fromInterventionId], references: [id])
  lines                InvoiceLine[]

  @@index([status], map: "idx_invoice_drafts_status")
  @@index([clientId], map: "idx_invoice_drafts_client_id")
  @@map("invoice_drafts")
}

model InvoiceLine {
  id               String            @id @default(cuid())
  invoiceId        String            @map("invoice_id")
  position         Int
  description      String
  quantity         Float
  unit             String
  unitPriceCents   Int               @map("unit_price_cents")
  discountCents    Int               @default(0) @map("discount_cents")
  vatCode          VatCode           @default(STANDARD) @map("vat_code")
  source           InvoiceLineSource @default(MANUAL)
  sourceRefId      String?           @map("source_ref_id")
  netAmountCents   Int               @map("net_amount_cents")
  vatAmountCents   Int               @map("vat_amount_cents")
  totalAmountCents Int               @map("total_amount_cents")
  invoice          InvoiceDraft      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId], map: "idx_invoice_lines_invoice_id")
  @@map("invoice_lines")
}

model Quote {
  id                    String      @id @default(cuid())
  number                String      @unique
  year                  Int
  sequence              Int
  clientId              Int         @map("client_id")
  propertyId            Int?        @map("property_id")
  subject               String
  status                QuoteStatus @default(BOZZA)
  validUntil            DateTime?   @map("valid_until")
  notes                 String?
  subtotalCents         Int         @default(0) @map("subtotal_cents")
  vatTotalCents         Int         @default(0) @map("vat_total_cents")
  totalCents            Int         @default(0) @map("total_cents")
  currency              String      @default("CHF")
  locale                String      @default("it")
  pdfUrl                String?     @map("pdf_url")
  pdfPublicId           String?     @map("pdf_public_id")
  sentAt                DateTime?   @map("sent_at")
  acceptedAt            DateTime?   @map("accepted_at")
  rejectedAt            DateTime?   @map("rejected_at")
  convertedToInvoiceId  String?     @map("converted_to_invoice_id")
  createdById           Int         @map("created_by_id")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")
  client                Client      @relation(fields: [clientId], references: [id])
  property              Property?   @relation(fields: [propertyId], references: [id])
  createdBy             User        @relation("QuoteCreator", fields: [createdById], references: [id])
  lines                 QuoteLine[]

  @@index([clientId], map: "idx_quotes_client_id")
  @@index([status], map: "idx_quotes_status")
  @@map("quotes")
}

model QuoteLine {
  id               String    @id @default(cuid())
  quoteId          String    @map("quote_id")
  position         Int
  description      String
  quantity         Float
  unit             String
  unitPriceCents   Int       @map("unit_price_cents")
  discountCents    Int       @default(0) @map("discount_cents")
  vatCode          VatCode   @default(STANDARD) @map("vat_code")
  netAmountCents   Int       @map("net_amount_cents")
  vatAmountCents   Int       @map("vat_amount_cents")
  totalAmountCents Int       @map("total_amount_cents")
  quote            Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId], map: "idx_quote_lines_quote_id")
  @@map("quote_lines")
}

model PriceListItem {
  id             String   @id @default(cuid())
  code           String   @unique
  description    String
  unit           String
  unitPriceCents Int      @map("unit_price_cents")
  vatCode        VatCode  @default(STANDARD) @map("vat_code")
  category       String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([active], map: "idx_price_list_active")
  @@map("price_list_items")
}

model NumberingCounter {
  id      String @id @default(cuid())
  prefix  String
  year    Int
  current Int    @default(0)

  @@unique([prefix, year])
  @@map("numbering_counters")
}

model SageExport {
  id               String           @id @default(cuid())
  batchNumber      String           @unique
  exportedAt       DateTime         @default(now()) @map("exported_at")
  exportedById     Int              @map("exported_by_id")
  exportedBy       User             @relation("SageExportExporter", fields: [exportedById], references: [id])
  invoiceCount     Int              @map("invoice_count")
  totalAmountCents Int              @map("total_amount_cents")
  csvFileName      String           @map("csv_file_name")
  zipUrl           String?          @map("zip_url")
  zipPublicId      String?          @map("zip_public_id")
  status           SageExportStatus @default(GENERATED)
  importedAt       DateTime?        @map("imported_at")
  importedById     Int?             @map("imported_by_id")
  importedBy       User?            @relation("SageExportImporter", fields: [importedById], references: [id])
  notes            String?
  invoices         InvoiceDraft[]   @relation("InvoiceExportBatch")

  @@map("sage_exports")
}

model AccountingConfig {
  id          String                   @id @default(cuid())
  key         String                   @unique
  value       String
  description String?
  category    AccountingConfigCategory
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  updatedById Int?                     @map("updated_by_id")

  @@map("accounting_configs")
}

model InterventionAuditLog {
  id             Int          @id @default(autoincrement())
  interventionId Int          @map("intervention_id")
  userId         Int          @map("user_id")
  changedField   String       @map("changed_field")
  oldValue       String?      @map("old_value")
  newValue       String?      @map("new_value")
  changedAt      DateTime     @default(now()) @map("changed_at")
  intervention   Intervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@index([interventionId], map: "idx_audit_logs_intervention_id")
  @@map("intervention_audit_logs")
}

enum ReportKind {
  INTERVENTION
  DAILY
  PROPERTY_HISTORY
  MONTHLY_HOURS
}

model GeneratedReport {
  id             String     @id @default(cuid())
  kind           ReportKind
  locale         String
  variant        String?
  interventionId Int?       @map("intervention_id")
  propertyId     Int?       @map("property_id")
  workerId       Int?       @map("worker_id")
  periodFrom     DateTime?  @map("period_from")
  periodTo       DateTime?  @map("period_to")
  pdfUrl         String     @map("pdf_url")
  pdfPublicId    String?    @map("pdf_public_id")
  generatedById  Int        @map("generated_by_id")
  generatedAt    DateTime   @default(now()) @map("generated_at")
  generatedBy    User       @relation(fields: [generatedById], references: [id])

  @@index([kind], map: "idx_generated_reports_kind")
  @@index([generatedById], map: "idx_generated_reports_generated_by")
  @@map("generated_reports")
}

enum IncomingDocumentType {
  FATTURA_FORNITORE
  RICEVUTA
  BOLLA_CONSEGNA
  PREVENTIVO_RICEVUTO
}

enum IncomingDocumentStatus {
  DA_VALIDARE
  VALIDATO
  PRONTO_EXPORT
  SCARTATO
}

model IncomingDocument {
  id              String                 @id @default(cuid())
  type            IncomingDocumentType
  status          IncomingDocumentStatus @default(DA_VALIDARE)
  fileUrl         String                 @map("file_url")
  filePublicId   String?                @map("file_public_id")
  mimeType        String?                @map("mime_type")
  rawOcrData      String?                @map("raw_ocr_data")
  extracted       String?
  verifiedData    String?                @map("verified_data")
  ocrConfidence   Float?                 @map("ocr_confidence")
  ocrProvider     String?                @map("ocr_provider")
  supplierName    String?                @map("supplier_name")
  supplierVat     String?                @map("supplier_vat")
  docNumber       String?                @map("doc_number")
  docDate         DateTime?              @map("doc_date")
  dueDate         DateTime?              @map("due_date")
  currency        String?                @default("CHF")
  subtotalCents   Int?                   @map("subtotal_cents")
  vatCents        Int?                   @map("vat_cents")
  totalCents      Int?                   @map("total_cents")
  iban            String?
  clientId        Int?                   @map("client_id")
  propertyId      Int?                   @map("property_id")
  interventionId  Int?                   @map("intervention_id")
  category        String?
  notes           String?
  discardReason   String?                @map("discard_reason")
  createdById     Int                    @map("created_by_id")
  validatedById   Int?                   @map("validated_by_id")
  validatedAt     DateTime?              @map("validated_at")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")
  createdBy       User                   @relation("IncomingDocumentCreator", fields: [createdById], references: [id])
  validatedBy     User?                  @relation("IncomingDocumentValidator", fields: [validatedById], references: [id])
  client          Client?                @relation(fields: [clientId], references: [id])
  property        Property?              @relation(fields: [propertyId], references: [id])
  intervention    Intervention?          @relation(fields: [interventionId], references: [id])

  @@index([status], map: "idx_incoming_documents_status")
  @@index([type], map: "idx_incoming_documents_type")
  @@index([docDate], map: "idx_incoming_documents_doc_date")
  @@index([clientId], map: "idx_incoming_documents_client_id")
  @@map("incoming_documents")
}

enum EmailLogType {
  INTERVENTION_REPORT
  QUOTE
  INVOICE_REMINDER
  ADMIN_ALERT_INTERVENTION_EXTRA_CLOSED
  ADMIN_ALERT_QUOTE_ACCEPTED
  ADMIN_ALERT_INVOICE_READY_EXPORT
  ADMIN_ALERT_OCR_DOC_TO_VALIDATE
}

enum EmailLogStatus {
  INVIATO
  FALLITO
  PREPARATO
}

model EmailLog {
  id                String         @id @default(cuid())
  type              EmailLogType
  status            EmailLogStatus
  referenceId       String         @map("reference_id")
  recipientEmail    String         @map("recipient_email")
  ccEmails          String?        @map("cc_emails")
  subject           String
  locale            String         @default("it")
  errorMessage      String?        @map("error_message")
  providerMessageId String?        @map("provider_message_id")
  attachmentName    String?        @map("attachment_name")
  retryCount        Int            @default(0) @map("retry_count")
  nextRetryAt       DateTime?      @map("next_retry_at")
  parentLogId       String?        @map("parent_log_id")
  sentById          Int            @map("sent_by_id")
  sentBy            User           @relation(fields: [sentById], references: [id])
  parentLog         EmailLog?      @relation("EmailLogRetryChain", fields: [parentLogId], references: [id])
  retries           EmailLog[]     @relation("EmailLogRetryChain")
  sentAt            DateTime       @default(now()) @map("sent_at")

  @@index([type], map: "idx_email_logs_type")
  @@index([status], map: "idx_email_logs_status")
  @@index([sentAt], map: "idx_email_logs_sent_at")
  @@index([referenceId], map: "idx_email_logs_reference_id")
  @@index([nextRetryAt], map: "idx_email_logs_next_retry_at")
  @@map("email_logs")
}
